end

local function CreateSlider(parent, text, min, max, step, default, callback)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, 0, 0, 45)
    container.BackgroundTransparency = 1
    
    local l = Instance.new("TextLabel", container)
    l.Size = UDim2.new(1, 0, 0, 20)
    l.Text = text .. ": " .. default
    l.TextColor3 = Color3.new(1, 1, 1)
    l.BackgroundTransparency = 1
    l.TextSize = 13
    l.Font = Enum.Font.Gotham
    l.TextXAlignment = Enum.TextXAlignment.Left
    
    local f = Instance.new("Frame", container)
    f.Size = UDim2.new(1, 0, 0, 8)
    f.Position = UDim2.new(0, 0, 0, 24)
    f.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    local corner = Instance.new("UICorner", f)
    corner.CornerRadius = UDim.new(1, 0)
    
    local sliderButton = Instance.new("ImageButton", container)
    sliderButton.Size = UDim2.new(0, 16, 0, 16)
    sliderButton.Position = UDim2.new((default - min) / (max - min), -8, 0, 20)
    sliderButton.BackgroundColor3 = baseColor:Lerp(Color3.new(1,1,1), 0.3)
    sliderButton.BorderSizePixel = 0
    sliderButton.AutoButtonColor = false
    local btnCorner = Instance.new("UICorner", sliderButton)
    btnCorner.CornerRadius = UDim.new(1, 0)
    
    local btnStroke = Instance.new("UIStroke", sliderButton)
    btnStroke.Color = Color3.new(1, 1, 1)
    btnStroke.Thickness = 1.5
    btnStroke.Transparency = 0.3
    
    local val = default
    local dragging = false
    
    local function updateFromPos(inputPos)
        local pos = math.clamp((inputPos - f.AbsolutePosition.X) / f.AbsoluteSize.X, 0, 1)
        val = math.floor(((min + (max - min) * pos) / step) + 0.5) * step
        val = math.clamp(val, min, max)
        sliderButton.Position = UDim2.new((val - min) / (max - min), -8, 0, 20)
        l.Text = text .. ": " .. val
        callback(val)
    end
    
    sliderButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    
    f.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateFromPos(input.Position.X)
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromPos(input.Position.X)
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return container, function() return val end
end

