applySpeed = function(value)
    if not wsActive then return end
    
    local char = Players.LocalPlayer.Character
    if not char then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local method = _G.bypassMethod or "FastChangeV2"
    
    _G.fastChangeActive = false
    _G.cframeActive = false
    _G.bodyVelocityActive = false
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if root and root:FindFirstChild("SpeedBypassBV") then
        root.SpeedBypassBV:Destroy()
    end
    
    if method == "FastChangeV2" then
        setupFastChangeV2(value)
    elseif method == "CFrame" then
        setupCFrameMethod(value)
    elseif method == "BodyVelocity" then
        setupBodyVelocity(value)
    else
        humanoid.WalkSpeed = value
    end
end

