-- ТРАСЕРЫ (ИСПРАВЛЕНЫ - ВСЕГДА ВИДНЫ)
local tracers = {}
local tracerEnabled = false
local tracerConnection = nil
local playerRemovingConnection = nil

local function clearTracers()
    for _, line in pairs(tracers) do
        if line then
            pcall(function() 
                line.Visible = false
                line:Remove() 
            end)
        end
    end
    tracers = {}
end

local function getPlayerHeadPosition(player)
    if not player.Character then return nil end
    local head = player.Character:FindFirstChild("Head")
    if head then return head.Position end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if root then return root.Position + Vector3.new(0, 1.5, 0) end
    return nil
end

local function setupTracers()
    clearTracers()
    
    playerRemovingConnection = Players.PlayerRemoving:Connect(function(player)
        if tracers[player] then
            pcall(function() 
                tracers[player].Visible = false
                tracers[player]:Remove() 
            end)
            tracers[player] = nil
        end
    end)
    
    tracerConnection = RunService.RenderStepped:Connect(function()
        if not tracerEnabled then return end
        
        local localPlayer = Players.LocalPlayer
        local camera = workspace.CurrentCamera
        local localHeadPos = getPlayerHeadPosition(localPlayer)
        
        if not localHeadPos then 
            for _, line in pairs(tracers) do line.Visible = false end
            return 
        end
        
        local startPos, onScreen = camera:WorldToViewportPoint(localHeadPos)
        local start2D = Vector2.new(startPos.X, startPos.Y)
        
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= localPlayer then
                local targetHeadPos = getPlayerHeadPosition(player)
                if targetHeadPos then
                    local endPos = camera:WorldToViewportPoint(targetHeadPos)
                    
                    -- ТРАСЕРЫ ВСЕГДА ВИДНЫ, даже если игрок не на экране
                    if not tracers[player] then
                        local line = Drawing.new("Line")
                        line.Color = Color3.fromRGB(255, 100, 255)
                        line.Thickness = 1.5
                        line.Transparency = 0.7  -- Полупрозрачные
                        tracers[player] = line
                    end
                    
                    local line = tracers[player]
                    line.From = start2D
                    line.To = Vector2.new(endPos.X, endPos.Y)
                    line.Visible = true
                elseif tracers[player] then
                    tracers[player].Visible = false
                end
            end
        end
        
        -- Очистка для игроков без персонажа
        for player, line in pairs(tracers) do
            if not player.Character then
                line.Visible = false
            end
        end
    end)
end

CreateToggle(visualSection, "TRACER ESP", function(s)
    tracerEnabled = s
    if s then
        if tracerConnection then tracerConnection:Disconnect() end
        if playerRemovingConnection then playerRemovingConnection:Disconnect() end
        clearTracers()
        setupTracers()
    else
        if tracerConnection then tracerConnection:Disconnect() end
        if playerRemovingConnection then playerRemovingConnection:Disconnect() end
        clearTracers()
    end
end)

