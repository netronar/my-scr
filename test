local curWS, wsActive = 100, false
local bypassThreads = {}
local fastChangeConnection = nil

local function stopBypassThreads()
    for _, thread in pairs(bypassThreads) do
        if thread then
            coroutine.close(thread)
        end
    end
    bypassThreads = {}
    
    if fastChangeConnection then
        fastChangeConnection:Disconnect()
        fastChangeConnection = nil
    end
end

local function applySpeed(value)
    if not wsActive then return end
    
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local method = _G.wsBypassMethod or "Стандартный"
    
    -- Очищаем старые методы
    stopBypassThreads()
    if root:FindFirstChild("SpeedBypassBV") then
        root.SpeedBypassBV:Destroy()
    end
    
    print("Применяем метод:", method, "со скоростью:", value)
    
    if method == "Стандартный" then
        humanoid.WalkSpeed = value
        
    elseif method == "BodyVelocity" then
        humanoid.WalkSpeed = 16
        
        local bv = Instance.new("BodyVelocity")
        bv.Name = "SpeedBypassBV"
        bv.MaxForce = Vector3.new(4000, 0, 4000)
        bv.Parent = root
        
        local thread = coroutine.create(function()
            while wsActive and _G.wsBypassMethod == "BodyVelocity" do
                if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                    bv.Velocity = humanoid.MoveDirection * value
                else
                    bv.Velocity = Vector3.new(0, bv.Velocity.Y, 0)
                end
                task.wait()
            end
            if root and root:FindFirstChild("SpeedBypassBV") then
                root.SpeedBypassBV:Destroy()
            end
        end)
        table.insert(bypassThreads, thread)
        coroutine.resume(thread)
        
    elseif method == "CFrame Manipulation" then
        humanoid.WalkSpeed = 16
        
        local thread = coroutine.create(function()
            while wsActive and _G.wsBypassMethod == "CFrame Manipulation" do
                if humanoid.MoveDirection.Magnitude > 0 then
                    local move = humanoid.MoveDirection * value * 0.03
                    root.CFrame = root.CFrame + move
                end
                task.wait(0.03)
            end
        end)
        table.insert(bypassThreads, thread)
        coroutine.resume(thread)
        
    elseif method == "Fast Change" then
        -- НОВЫЙ МЕТОД: быстрая смена скорости в цикле
        humanoid.WalkSpeed = 16 -- Начальная скорость
        
        fastChangeConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if wsActive and _G.wsBypassMethod == "Fast Change" and humanoid and humanoid.Parent then
                -- Постоянно меняем скорость взад-вперед
                local current = humanoid.WalkSpeed
                if current < value then
                    humanoid.WalkSpeed = math.min(current + 5, value)
                elseif current > value then
                    humanoid.WalkSpeed = math.max(current - 5, value)
                end
                
                -- Добавляем небольшие флуктуации чтобы античит не замечал
                if math.random() > 0.7 then
                    humanoid.WalkSpeed = humanoid.WalkSpeed + math.random(-2, 2)
                end
            end
        end)
        
    elseif method == "Legacy" then
        humanoid.WalkSpeed = value
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end
end

