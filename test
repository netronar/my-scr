-- ТРАСЕРЫ
local tracers = {}
local tracerEnabled = false
local tracerConnection = nil
local playerRemovingConnection = nil

local function clearTracers()
    for _, line in pairs(tracers) do
        if line then
            pcall(function() 
                line.Visible = false
                line:Remove() 
            end)
        end
    end
    tracers = {}
end

local function getPlayerHeadPosition(player)
    if not player.Character then return nil end
    local head = player.Character:FindFirstChild("Head")
    if head then return head.Position end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if root then return root.Position + Vector3.new(0, 1.5, 0) end
    return nil
end

local function setupTracers()
    clearTracers()
    
    playerRemovingConnection = game.Players.PlayerRemoving:Connect(function(player)
        if tracers[player] then
            pcall(function() 
                tracers[player].Visible = false
                tracers[player]:Remove() 
            end)
            tracers[player] = nil
        end
    end)
    
    tracerConnection = game:GetService("RunService").RenderStepped:Connect(function()
        if not tracerEnabled then return end
        
        local localPlayer = game.Players.LocalPlayer
        if not localPlayer then return end
        
        local camera = workspace.CurrentCamera
        if not camera then return end
        
        local localHeadPos = getPlayerHeadPosition(localPlayer)
        if not localHeadPos then 
            for _, line in pairs(tracers) do
                line.Visible = false
            end
            return 
        end
        
        local startPos, onScreen = camera:WorldToViewportPoint(localHeadPos)
        if not onScreen then 
            for _, line in pairs(tracers) do
                line.Visible = false
            end
            return 
        end
        
        local start2D = Vector2.new(startPos.X, startPos.Y)
        local activePlayers = 0
        
        for _, player in pairs(game.Players:GetPlayers()) do
            if player ~= localPlayer and player.Character then
                local targetHeadPos = getPlayerHeadPosition(player)
                if targetHeadPos then
                    local endPos, onScreenTarget = camera:WorldToViewportPoint(targetHeadPos)
                    
                    if onScreenTarget then
                        if not tracers[player] then
                            local line = Drawing.new("Line")
                            line.Visible = false
                            line.Color = Color3.fromRGB(255, 100, 255)
                            line.Thickness = 1.5
                            line.Transparency = 1
                            tracers[player] = line
                        end
                        
                        local line = tracers[player]
                        line.From = start2D
                        line.To = Vector2.new(endPos.X, endPos.Y)
                        line.Visible = true
                        activePlayers = activePlayers + 1
                    else
                        if tracers[player] then
                            tracers[player].Visible = false
                        end
                    end
                else
                    if tracers[player] then
                        tracers[player].Visible = false
                    end
                end
            end
        end
        
        if activePlayers == 0 then
            for _, line in pairs(tracers) do
                line.Visible = false
            end
        end
        
        for player, line in pairs(tracers) do
            if not game.Players:FindFirstChild(player.Name) or not player.Character then
                pcall(function() 
                    line.Visible = false
                    line:Remove() 
                end)
                tracers[player] = nil
            end
        end
    end)
end

CreateToggle(visualSection, "TRACER ESP (ОТ ПЕРСОНАЖА)", function(s)
    tracerEnabled = s
    
    if s then
        if tracerConnection then
            tracerConnection:Disconnect()
            tracerConnection = nil
        end
        if playerRemovingConnection then
            playerRemovingConnection:Disconnect()
            playerRemovingConnection = nil
        end
        clearTracers()
        setupTracers()
    else
        if tracerConnection then
            tracerConnection:Disconnect()
            tracerConnection = nil
        end
        if playerRemovingConnection then
            playerRemovingConnection:Disconnect()
            playerRemovingConnection = nil
        end
        clearTracers()
    end
end)

