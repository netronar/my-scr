local function updateGUISize()
    local newWidth = tonumber(WidthInput.Text) or settings.width
    local newHeight = tonumber(HeightInput.Text) or settings.height
    
    newWidth = math.max(newWidth, settings.minSize)
    newHeight = math.max(newHeight, settings.minSize)
    
    settings.width = newWidth
    settings.height = newHeight
    
    fullSize = UDim2.new(0, settings.width, 0, settings.height)
    minimizedSize = UDim2.new(0, settings.width, 0, 45)
    
    if not isMinimized then
        Main.Size = fullSize
    else
        Main.Size = minimizedSize
    end
    
    Main.Position = UDim2.new(0.5, -settings.width/2, 0.5, -settings.height/2)
    
    WidthLabel.Text = "Ширина: " .. settings.width
    HeightLabel.Text = "Высота: " .. settings.height
    WidthInput.Text = tostring(settings.width)
    HeightInput.Text = tostring(settings.height)
end

