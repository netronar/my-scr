local function UpdateList()
    for _, child in pairs(ScrollL:GetChildren()) do 
        if child:IsA("Frame") then 
            child:Destroy() 
        end 
    end
    
    for _, player in pairs(game.Players:GetPlayers()) do 
        if player ~= game.Players.LocalPlayer then
            local F = Instance.new("Frame", ScrollL)
            F.Size = UDim2.new(0.95, 0, 0, 45)
            F.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
            Instance.new("UICorner", F).CornerRadius = UDim.new(0, 6)
            
            local L = Instance.new("TextLabel", F)
            L.Size = UDim2.new(0.7, 0, 1, 0)
            L.Position = UDim2.new(0, 10, 0, 0)
            L.Text = player.DisplayName .. "\n(@" .. player.Name .. ")"
            L.TextColor3 = Color3.new(1, 1, 1)
            L.BackgroundTransparency = 1
            L.TextXAlignment = Enum.TextXAlignment.Left
            L.TextSize = 14
            L.Font = Enum.Font.SourceSansBold
            
            local B = Instance.new("TextButton", F)
            B.Size = UDim2.new(0.2, 0, 0.8, 0)
            B.Position = UDim2.new(0.75, 0, 0.1, 0)
            B.Text = "ТП"
            B.BackgroundColor3 = Color3.fromRGB(80, 160, 80)
            B.TextColor3 = Color3.new(1, 1, 1)
            B.TextSize = 18
            B.Font = Enum.Font.SourceSansBold
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 4)
            
            B.MouseButton1Click:Connect(function() 
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local localChar = game.Players.LocalPlayer.Character
                    if localChar and localChar:FindFirstChild("HumanoidRootPart") then
                        localChar.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame
                    end
                end 
            end)
        end 
    end
end

