local function CreateToggle(parent, text, callback, default)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(1, 0, 0, 40)
    b.Text = text .. ": OFF"
    b.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.SourceSansBold
    b.TextSize = 18
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
    
    local state = default or false
    if state then
        b.Text = text .. ": ON"
        b.BackgroundColor3 = Color3.fromRGB(110, 80, 160)
    end
    
    b.MouseButton1Click:Connect(function()
        state = not state
        b.Text = text .. ": " .. (state and "ON" or "OFF")
        b.BackgroundColor3 = state and Color3.fromRGB(110, 80, 160) or Color3.fromRGB(60, 60, 70)
        callback(state)
    end)
    return b, state
end

local function CreateDropdown(parent, text, options, default, callback)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, 0, 0, 70)
    container.BackgroundTransparency = 1
    container.Name = "DropdownContainer"
    
    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, 0, 0, 25)
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.BackgroundTransparency = 1
    label.TextSize = 16
    label.Font = Enum.Font.SourceSansBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local button = Instance.new("TextButton", container)
    button.Size = UDim2.new(1, 0, 0, 35)
    button.Position = UDim2.new(0, 0, 0, 30)
    button.Text = default or options[1]
    button.BackgroundColor3 = Color3.fromRGB(70, 70, 80)
    button.TextColor3 = Color3.new(1, 1, 1)
    button.Font = Enum.Font.SourceSans
    button.TextSize = 16
    Instance.new("UICorner", button).CornerRadius = UDim.new(0, 6)
    
    local dropdown = Instance.new("ScrollingFrame", container)
    dropdown.Size = UDim2.new(1, 0, 0, 200)
    dropdown.Position = UDim2.new(0, 0, 0, 67)
    dropdown.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    dropdown.Visible = false
    dropdown.ScrollBarThickness = 4
    dropdown.ZIndex = 10
    dropdown.BorderSizePixel = 0
    Instance.new("UICorner", dropdown).CornerRadius = UDim.new(0, 6)
    
    local layout = Instance.new("UIListLayout", dropdown)
    layout.Padding = UDim.new(0, 2)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    local selected = default or options[1]
    
    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton", dropdown)
        optBtn.Size = UDim2.new(1, 0, 0, 35)
        optBtn.Text = opt
        optBtn.BackgroundColor3 = opt == selected and Color3.fromRGB(110, 80, 160) or Color3.fromRGB(60, 60, 70)
        optBtn.TextColor3 = Color3.new(1, 1, 1)
        optBtn.Font = Enum.Font.SourceSans
        optBtn.TextSize = 16
        optBtn.ZIndex = 11
        optBtn.BorderSizePixel = 0
        Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0, 4)
        
        optBtn.MouseButton1Click:Connect(function()
            selected = opt
            button.Text = opt
            dropdown.Visible = false
            for _, b in pairs(dropdown:GetChildren()) do
                if b:IsA("TextButton") then
                    b.BackgroundColor3 = b.Text == selected and Color3.fromRGB(110, 80, 160) or Color3.fromRGB(60, 60, 70)
                end
            end
            callback(opt)
        end)
    end
    
    button.MouseButton1Click:Connect(function()
        dropdown.Visible = not dropdown.Visible
    end)
    
    return container, function() return selected end
end

local function CreateSlider(parent, text, min, max, step, default, callback)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, 0, 0, 50)
    container.BackgroundTransparency = 1
    
    local l = Instance.new("TextLabel", container)
    l.Size = UDim2.new(1, 0, 0, 25)
    l.Text = text .. ": " .. default
    l.TextColor3 = Color3.new(1, 1, 1)
    l.BackgroundTransparency = 1
    l.TextSize = 16
    l.Font = Enum.Font.SourceSansBold
    l.TextXAlignment = Enum.TextXAlignment.Left
    
    local f = Instance.new("Frame", container)
    f.Size = UDim2.new(1, 0, 0, 10)
    f.Position = UDim2.new(0, 0, 0, 30)
    f.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Instance.new("UICorner", f).CornerRadius = UDim.new(1, 0)
    
    local bar = Instance.new("Frame", f)
    bar.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    bar.BackgroundColor3 = Color3.fromRGB(140, 100, 220)
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
    
    local val = default
    
    local function update(input)
        local pos = math.clamp((input.Position.X - f.AbsolutePosition.X) / f.AbsoluteSize.X, 0, 1)
        val = math.clamp(math.floor(((min + (max - min) * pos) / step) + 0.5) * step, min, max)
        bar.Size = UDim2.new((val - min) / (max - min), 0, 1, 0)
        l.Text = text .. ": " .. val
        callback(val)
    end
    
    f.InputBegan:Connect(function(i) 
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            local m; m = UIS.InputChanged:Connect(function(inp) 
                if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then 
                    update(inp) 
                end 
            end)
            local e; e = UIS.InputEnded:Connect(function(inp) 
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then 
                    m:Disconnect() 
                    e:Disconnect() 
                end 
            end)
            update(i)
        end 
    end)
    
    return container, function() return val end
end

