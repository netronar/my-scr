-- Fast Change V2
local function setupFastChangeV2(targetSpeed)
    local humanoid = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    humanoid.WalkSpeed = 16
    _G.fastChangeTarget = targetSpeed
    _G.fastChangeActive = true
    _G.bypassMethod = "FastChangeV2"
    
    task.spawn(function()
        while _G.fastChangeActive and wsActive and _G.bypassMethod == "FastChangeV2" do
            if humanoid.WalkSpeed < 16 then
                humanoid.WalkSpeed = _G.fastChangeTarget
            elseif humanoid.WalkSpeed < _G.fastChangeTarget then
                humanoid.WalkSpeed = math.min(humanoid.WalkSpeed + 2, _G.fastChangeTarget)
            end
            task.wait(0.3)
        end
    end)
end

-- CFrame метод
local function setupCFrameMethod(targetSpeed)
    local humanoid = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("Humanoid")
    local root = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not root then return end
    
    humanoid.WalkSpeed = 16
    _G.cframeActive = true
    _G.bypassMethod = "CFrame"
    
    task.spawn(function()
        while _G.cframeActive and wsActive and _G.bypassMethod == "CFrame" do
            local moveDir = humanoid.MoveDirection
            if moveDir.Magnitude > 0 then
                root.CFrame = root.CFrame + (moveDir * targetSpeed * 0.03)
            end
            task.wait(0.03)
        end
    end)
end

-- BodyVelocity метод
local function setupBodyVelocity(targetSpeed)
    local humanoid = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("Humanoid")
    local root = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not root then return end
    
    humanoid.WalkSpeed = 16
    _G.bodyVelocityActive = true
    _G.bypassMethod = "BodyVelocity"
    
    local bv = Instance.new("BodyVelocity")
    bv.Name = "SpeedBypassBV"
    bv.MaxForce = Vector3.new(4000, 0, 4000)
    bv.Parent = root
    
    task.spawn(function()
        while _G.bodyVelocityActive and wsActive and _G.bypassMethod == "BodyVelocity" do
            if humanoid.MoveDirection.Magnitude > 0 then
                bv.Velocity = humanoid.MoveDirection * targetSpeed
            else
                bv.Velocity = Vector3.new(0, bv.Velocity.Y, 0)
            end
            task.wait()
        end
        if bv and bv.Parent then
            bv:Destroy()
        end
    end)
end

